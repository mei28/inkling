{
  "manifest_version": 3,
  "name": "inkling",
  "version": "0.1.0",
  "description": "Highlight color codes on web pages",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-enabled": {
      "suggested_key": {
        "default": "Alt+Shift+C"
      },
      "description": "Toggle inkling on/off"
    }
  },
  "icons": {}
}
