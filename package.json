{
  "name": "inkling",
  "version": "0.1.0",
  "private": true,
  "description": "Highlight color codes on web pages",
  "type": "module",
  "scripts": {
    "build": "node esbuild.mjs",
    "dev": "node esbuild.mjs --watch",
    "test": "vitest run",
    "lint": "biome check .",
    "fmt": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/chrome": "^0.0.287",
    "esbuild": "^0.24.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
